msgid "project.subscription.title"
msgstr "Email Subscription & Dispatch Module"

msgid "project.subscription.summary"
msgstr "Modul backendowy do zarzadzania subskrypcjami email, potwierdzaniem subskrypcji, logika wypisania oraz masowymi kampaniami email."

msgid "project.subscription.item.1"
msgstr "Potwierdzanie subskrypcji za pomoca jednorazowego kodu."

msgid "project.subscription.item.2"
msgstr "Przechowywanie i walidacja kodow potwierdzenia w Redis."

msgid "project.subscription.item.3"
msgstr "Aktywacja subskrypcji new_events i super_price."

msgid "project.subscription.item.4"
msgstr "Powiadomienia email o zmianach statusu subskrypcji."

msgid "project.subscription.item.5"
msgstr "Masowa wysylka emaili do subskrybentow."

msgid "project.subscription.item.6"
msgstr "Filtrowanie tresci wedlug jezyka, miast, sekcji oraz historii zamowien klienta."

msgid "project.subscription.item.7"
msgstr "HTML email templates po rosyjsku i hebrajsku."

msgid "project.subscription.item.8"
msgstr "Logowanie wysylki emaili i obsluga bledow."

msgid "project.subscription.tech"
msgstr "Python, Flask, MySQL, Redis, HTML Templates, Email, REST API, JavaScript"

msgid "project.mail_analyzer.title"
msgstr "Mail Analyzer / Bounce Email Processing"

msgid "project.mail_analyzer.summary"
msgstr "Modul do analizy powiadomien bounce/DSN i wykrywania adresow email z problemami dostarczania."

msgid "project.mail_analyzer.item.1"
msgstr "Integracja Gmail API przez OAuth."

msgid "project.mail_analyzer.item.2"
msgstr "Przetwarzanie przychodzacych wiadomosci email."

msgid "project.mail_analyzer.item.3"
msgstr "Parsowanie struktur MIME/DSN oraz naglowkow X-Failed-Recipients."

msgid "project.mail_analyzer.item.4"
msgstr "Ekstrakcja problematycznych adresow email z naglowkow i tresci wiadomosci."

msgid "project.mail_analyzer.item.5"
msgstr "Obsluga przypadkow takich jak user unknown, mailbox unavailable, address not found, quarantine/spam, inactive email oraz changed email address."

msgid "project.mail_analyzer.item.6"
msgstr "Analiza tresci emaili oparta na wyrazeniach regularnych."

msgid "project.mail_analyzer.item.7"
msgstr "Generowanie raportow JSON dla kandydatow do wypisania. Uzycie OpenAI API jako fallback dla zlozonej analizy tresci emaili."

msgid "project.mail_analyzer.tech"
msgstr "Python, Gmail API, OAuth, Regex, MySQL, JSON, OpenAI API"

msgid "project.exim.title"
msgstr "Exim Mail Log Analyzer"

msgid "project.exim.summary"
msgstr "Male wewnetrzne narzedzie CLI do analizy logow serwera pocztowego Exim. Projekt jest nadal w trakcie realizacji."

msgid "project.exim.item.1"
msgstr "Analiza plikow mainlog oraz archiwalnych mainlog.*.gz dla wybranego okresu."

msgid "project.exim.item.2"
msgstr "Wyszukiwanie wpisow failed i deferred delivery."

msgid "project.exim.item.3"
msgstr "Ekstrakcja adresow email z logow Exim."

msgid "project.exim.item.4"
msgstr "Klasyfikacja problemow: nonexistent user, unavailable mailbox, typo domain, temporary errors, blokada Spamhaus."

msgid "project.exim.item.5"
msgstr "Generowanie raportow .txt, .csv oraz summary.txt."

msgid "project.exim.item.6"
msgstr "Generowanie pliku SQL import dla procesu wypisania."

msgid "project.exim.tech"
msgstr "Python, Regex, CSV, Gzip, CLI, Exim logs, SQL"

msgid "project.admin.title"
msgstr "Admin Module for Smarticket / Bravo"

msgid "project.admin.summary"
msgstr "Jeden z pierwszych modulow backendowych dla wewnetrznego panelu administracyjnego."

msgid "project.admin.item.1"
msgstr "Flask routes do zarzadzania relacjami miedzy uzytkownikami, salami i producentami."

msgid "project.admin.item.2"
msgstr "Dodawanie i usuwanie relacji miedzy uzytkownikiem a sala."

msgid "project.admin.item.3"
msgstr "Dodawanie i usuwanie relacji miedzy uzytkownikiem a producentem."

msgid "project.admin.item.4"
msgstr "Sprawdzanie zaleznosci przed usunieciem, aby nie usunac encji polaczonych z sesjami."

msgid "project.admin.item.5"
msgstr "Renderowanie HTML templates z Jinja. Funkcje JavaScript dla zapytan AJAX i dynamicznych aktualizacji interfejsu."

msgid "project.admin.item.6"
msgstr "Obsluga odpowiedzi sukcesu i bledow po stronie frontendu."

msgid "project.admin.tech"
msgstr "Python, Flask, MySQL, Jinja, JavaScript, HTML, Bootstrap"

