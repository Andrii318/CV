msgid "job.resp.1"
msgstr "Tworzylem moduly backendowe w Python dla wewnetrznych serwisow firmy."

msgid "job.resp.2"
msgstr "Tworzylem i utrzymywalem Flask routes dla funkcji administracyjnych i uzytkownika."

msgid "job.resp.3"
msgstr "Pracowalem z MySQL, zlozonymi zapytaniami SQL, warstwami DAO oraz bezpiecznymi aktualizacjami transakcyjnymi."

msgid "job.resp.4"
msgstr "Uzywalem Redis do tymczasowego przechowywania danych, jednorazowych kodow potwierdzenia oraz logiki serwisowej."

msgid "job.resp.5"
msgstr "Rozwijalem wielojezyczne przeplywy subskrypcji email: potwierdzenie, wypisanie, powiadomienia statusowe oraz wysylke w tle."

msgid "job.resp.6"
msgstr "Pracowalem z HTML email templates oraz logika wielojezyczna dla rosyjskiego i hebrajskiego."

msgid "job.resp.7"
msgstr "Integrowalem wewnetrzne API dla wydarzen, ustawien seller/domain, mirror sellers oraz personalizacji wedlug historii zamowien."

msgid "job.resp.8"
msgstr "Budowalem narzedzia do analizy email delivery failures, wiadomosci bounce/DSN, ruchu Gmail oraz raportow kandydatow do wypisania."

msgid "job.resp.9"
msgstr "Korzystalem z Git, Bitbucket i Postman do developmentu, testow i pracy zespolowej. Wspieralem, ulepszalem i rozszerzalem istniejace serwisy."

