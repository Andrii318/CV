msgid "job.resp.1"
msgstr "Tworzylem moduly backendowe w Python dla wewnetrznych serwisow firmy."

msgid "job.resp.2"
msgstr "Tworzylem i utrzymywalem Flask routes dla funkcji administracyjnych i zwiazanych z uzytkownikiem."

msgid "job.resp.3"
msgstr "Pracowalem z bazami danych MySQL, zapytaniami SQL i warstwami DAO."

msgid "job.resp.4"
msgstr "Uzywalem Redis do tymczasowego przechowywania danych, jednorazowych kodow potwierdzenia oraz logiki serwisowej."

msgid "job.resp.5"
msgstr "Rozwijalem moduly do subskrypcji email, potwierdzania subskrypcji, unsubscribe flows oraz masowej wysylki emaili."

msgid "job.resp.6"
msgstr "Pracowalem z HTML email templates oraz logika wielojezyczna dla rosyjskiego i hebrajskiego."

msgid "job.resp.7"
msgstr "Integrowalem zewnetrzne API do pobierania danych o wydarzeniach, sprzedawcach, domenach i historii zamowien klientow."

msgid "job.resp.8"
msgstr "Tworzylem narzedzia do analizy bledow dostarczania emaili, bounce messages i logow serwera pocztowego."

msgid "job.resp.9"
msgstr "Korzystalem z Git, Bitbucket i Postman do developmentu, testow i pracy zespolowej. Wspieralem i rozwijalem istniejaca funkcjonalnosc."

