msgid "project.subscription.title"
msgstr "Platforma subskrypcji i wysylek"

msgid "project.subscription.summary"
msgstr "Wielojezyczny backendowy serwis do ustawien subskrybenta, kodow potwierdzenia, wypisania, masowych wysylek oraz zgodnosci z legacy-systemem subskrypcji Bravo."

msgid "project.subscription.item.1"
msgstr "Publiczne i wewnetrzne Flask routes dla ustawien subskrybenta, potwierdzenia, wypisania, migracji oraz sync-flow."

msgid "project.subscription.item.2"
msgstr "Jednorazowe kody potwierdzenia w Redis z ochrona przed ponownym uzyciem."

msgid "project.subscription.item.3"
msgstr "Oddzielne statusy subskrypcji dla rosyjskiego i hebrajskiego z logika seller mirrors."

msgid "project.subscription.item.4"
msgstr "Jeden email statusowy dla wlaczenia, wylaczenia oraz mieszanych zmian subskrypcji."

msgid "project.subscription.item.5"
msgstr "Wysylka super_price w tle z batchingiem i logami wysylek."

msgid "project.subscription.item.6"
msgstr "Filtrowanie tresci wedlug jezyka, miast, sekcji oraz historii zamowien klienta."

msgid "project.subscription.item.7"
msgstr "HTML email templates oraz wybor domeny dla rosyjskich i hebrajskich seller pages."

msgid "project.subscription.item.8"
msgstr "Legacy-synchronizacja oraz import subskrybentow, filtrow i historii ze starych tickets tables."

msgid "project.subscription.tech"
msgstr "Python, Flask, MySQL, Redis, REST API, Jinja/HTML Email, threading"

msgid "project.mail_analyzer.title"
msgstr "Mail Analyzer / Bounce Processing"

msgid "project.mail_analyzer.summary"
msgstr "Wewnetrzny serwis analizy bledow email, ktory przetwarza Gmail bounce traffic i tworzy kandydatow do wypisania."

msgid "project.mail_analyzer.item.1"
msgstr "Integracja Gmail API przez OAuth."

msgid "project.mail_analyzer.item.2"
msgstr "Asynchroniczne przetwarzanie przez osobny analyze endpoint z blokada rownoleglego uruchomienia."

msgid "project.mail_analyzer.item.3"
msgstr "Scisle parsowanie struktur MIME/DSN oraz naglowkow X-Failed-Recipients."

msgid "project.mail_analyzer.item.4"
msgstr "Ekstrakcja problematycznych adresow z naglowkow, czesci DSN oraz tresci wiadomosci."

msgid "project.mail_analyzer.item.5"
msgstr "Klasyfikacja przypadkow: user unknown, mailbox unavailable, quarantine/spam, inactive email oraz changed email address."

msgid "project.mail_analyzer.item.6"
msgstr "Etapowa analiza regex przed fallbackiem do LLM."

msgid "project.mail_analyzer.item.7"
msgstr "Generowanie raportow JSON ze statystykami i cleanupem danych. OpenAI API bylo fallbackiem dla trudnych emaili."

msgid "project.mail_analyzer.tech"
msgstr "Python, Gmail API, OAuth, MIME/DSN, Regex, JSON, OpenAI API"

msgid "project.exim.title"
msgstr "Serwis integracji z Bravo DB"

msgid "project.exim.summary"
msgstr "Wewnetrzne Flask API nad danymi Bravo MySQL uzywane w workflow subskrypcji i wysylek."

msgid "project.exim.item.1"
msgstr "REST endpoints dla super price shows, seller domains, active sellers, order history oraz wszystkich emaili powiazanych z dokumentem klienta."

msgid "project.exim.item.2"
msgstr "Zlozone SQL joins na orders, shows, seances, halls, cities, sellers, partners oraz discount tables."

msgid "project.exim.item.3"
msgstr "Agregacja metadanych show, zakresow dat, list miast oraz discount flags dla kampanii wysylkowych."

msgid "project.exim.item.4"
msgstr "Pobieranie historii zamowien klienta do personalizacji wedlug regionu i sekcji."

msgid "project.exim.item.5"
msgstr "Mapowanie sprzedawcow i domen z mirror IDs oraz statusem aktywnosci partnera."

msgid "project.exim.item.6"
msgstr "Wielokrotnego uzytku MySQL gateway z connection pooling, retry logika oraz jawnym sterowaniem transakcjami."

msgid "project.exim.tech"
msgstr "Python, Flask, MySQL, SQL, REST API, connection pooling"

msgid "project.admin.title"
msgstr "Zgodnosc i migracja legacy Bravo"

msgid "project.admin.summary"
msgstr "Warstwa zgodnosci i procesy migracyjne miedzy nowym dispatch-service a legacy-ekosystemem subskrypcji Bravo/global_bravo."

msgid "project.admin.item.1"
msgstr "Best-effort synchronizacja z powrotem do legacy tabel Subscribe i SubscribeHistory."

msgid "project.admin.item.2"
msgstr "Zachowanie i generowanie legacy identyfikatorow SID dla zgodnosci subskrybentow."

msgid "project.admin.item.3"
msgstr "Synchronizacja miast i sekcji pomiedzy nowym i starym schematem."

msgid "project.admin.item.4"
msgstr "Import w tle subskrybentow, filtrow, historii, miast i sekcji ze starych tickets tables."

msgid "project.admin.item.5"
msgstr "Wsparcie dla legacy CRM flows oraz wielojezycznych subscribe/unsubscribe templates w ekosystemie Bravo."

msgid "project.admin.item.6"
msgstr "Bezpieczna obsluga null dates i roznic pomiedzy starym a nowym schematem bazy."

msgid "project.admin.tech"
msgstr "Python, Flask, MySQL, SQL, data migration, legacy systems"

