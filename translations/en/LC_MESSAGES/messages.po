msgid "project.subscription.title"
msgstr "Email Subscription & Dispatch Module"

msgid "project.subscription.summary"
msgstr "Backend module for managing email subscriptions, subscription confirmation, unsubscribe logic, and mass email campaigns."

msgid "project.subscription.item.1"
msgstr "Subscription confirmation via one-time confirmation code."

msgid "project.subscription.item.2"
msgstr "Redis-based storage and validation of confirmation codes."

msgid "project.subscription.item.3"
msgstr "Activation of new_events and super_price subscriptions."

msgid "project.subscription.item.4"
msgstr "Email notifications about subscription status changes."

msgid "project.subscription.item.5"
msgstr "Mass email dispatching to subscribers."

msgid "project.subscription.item.6"
msgstr "Content filtering by language, cities, sections, and customer order history."

msgid "project.subscription.item.7"
msgstr "HTML email templates in Russian and Hebrew."

msgid "project.subscription.item.8"
msgstr "Logging of email sending and error handling."

msgid "project.subscription.tech"
msgstr "Python, Flask, MySQL, Redis, HTML Templates, Email, REST API, JavaScript"

msgid "project.mail_analyzer.title"
msgstr "Mail Analyzer / Bounce Email Processing"

msgid "project.mail_analyzer.summary"
msgstr "Module for analyzing bounce/DSN notifications and detecting email addresses with delivery problems."

msgid "project.mail_analyzer.item.1"
msgstr "Gmail API integration via OAuth."

msgid "project.mail_analyzer.item.2"
msgstr "Processing of incoming email messages."

msgid "project.mail_analyzer.item.3"
msgstr "Parsing of MIME/DSN structures and X-Failed-Recipients headers."

msgid "project.mail_analyzer.item.4"
msgstr "Extraction of problematic email addresses from headers and email body."

msgid "project.mail_analyzer.item.5"
msgstr "Handling cases such as user unknown, mailbox unavailable, address not found, quarantine/spam, inactive email, and changed email address."

msgid "project.mail_analyzer.item.6"
msgstr "Regular expression based analysis of email text."

msgid "project.mail_analyzer.item.7"
msgstr "JSON report generation for unsubscribe candidates. OpenAI API usage as a fallback for complex email text analysis."

msgid "project.mail_analyzer.tech"
msgstr "Python, Gmail API, OAuth, Regex, MySQL, JSON, OpenAI API"

msgid "project.exim.title"
msgstr "Exim Mail Log Analyzer"

msgid "project.exim.summary"
msgstr "Small internal CLI tool for analyzing Exim mail server logs. The project is still in progress."

msgid "project.exim.item.1"
msgstr "Analysis of mainlog and archived mainlog.*.gz files for a selected time period."

msgid "project.exim.item.2"
msgstr "Search for failed and deferred delivery log entries."

msgid "project.exim.item.3"
msgstr "Extraction of email addresses from Exim logs."

msgid "project.exim.item.4"
msgstr "Classification of issues: nonexistent user, unavailable mailbox, typo domain, temporary errors, Spamhaus blocking."

msgid "project.exim.item.5"
msgstr "Generation of .txt, .csv, and summary.txt reports."

msgid "project.exim.item.6"
msgstr "Generation of an SQL import file for unsubscribe processing."

msgid "project.exim.tech"
msgstr "Python, Regex, CSV, Gzip, CLI, Exim logs, SQL"

