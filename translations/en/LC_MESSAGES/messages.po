msgid "project.subscription.title"
msgstr "Subscription Dispatch Platform"

msgid "project.subscription.summary"
msgstr "Multilingual backend service for subscriber settings, confirmation codes, unsubscribe flows, mass dispatching, and compatibility with the Bravo legacy subscription system."

msgid "project.subscription.item.1"
msgstr "Public and internal Flask routes for subscriber settings, confirmation, unsubscribe, migration, and sync flows."

msgid "project.subscription.item.2"
msgstr "Redis-based one-time confirmation codes with reuse protection."

msgid "project.subscription.item.3"
msgstr "Separate Russian and Hebrew subscription states with seller mirror logic."

msgid "project.subscription.item.4"
msgstr "Single status email for enable, disable, or mixed subscription changes."

msgid "project.subscription.item.5"
msgstr "Background super_price dispatch with batching and send logs."

msgid "project.subscription.item.6"
msgstr "Content filtering by language, cities, sections, and customer order history."

msgid "project.subscription.item.7"
msgstr "HTML email templates and domain resolution for Russian and Hebrew seller pages."

msgid "project.subscription.item.8"
msgstr "Legacy synchronization and import of subscribers, filters, and history from old tickets tables."

msgid "project.subscription.tech"
msgstr "Python, Flask, MySQL, Redis, REST API, Jinja/HTML Email, threading"

msgid "project.mail_analyzer.title"
msgstr "Mail Analyzer / Bounce Processing"

msgid "project.mail_analyzer.summary"
msgstr "Internal email failure analysis service that processes Gmail bounce traffic and produces unsubscribe candidates."

msgid "project.mail_analyzer.item.1"
msgstr "Gmail API integration via OAuth."

msgid "project.mail_analyzer.item.2"
msgstr "Asynchronous processing through a dedicated analyze endpoint with run locking."

msgid "project.mail_analyzer.item.3"
msgstr "Strict parsing of MIME/DSN structures and X-Failed-Recipients headers."

msgid "project.mail_analyzer.item.4"
msgstr "Extraction of failed addresses from headers, DSN parts, and message body."

msgid "project.mail_analyzer.item.5"
msgstr "Classification of cases such as user unknown, mailbox unavailable, quarantine/spam, inactive email, and changed email address."

msgid "project.mail_analyzer.item.6"
msgstr "Staged regex-based analysis before LLM fallback."

msgid "project.mail_analyzer.item.7"
msgstr "JSON report generation with summary statistics, cleanup, and OpenAI fallback for complex emails."

msgid "project.mail_analyzer.tech"
msgstr "Python, Gmail API, OAuth, MIME/DSN, Regex, JSON, OpenAI API"

msgid "project.exim.title"
msgstr "Bravo DB Integration Service"

msgid "project.exim.summary"
msgstr "Internal Flask API over Bravo MySQL data used by subscription and dispatch workflows."

msgid "project.exim.item.1"
msgstr "REST endpoints for super price shows, seller domains, active sellers, order history, and all emails linked to a customer document."

msgid "project.exim.item.2"
msgstr "Complex SQL joins across orders, shows, seances, halls, cities, sellers, partners, and discount tables."

msgid "project.exim.item.3"
msgstr "Aggregation of show metadata, date ranges, city lists, and discount flags for dispatch campaigns."

msgid "project.exim.item.4"
msgstr "Customer order history retrieval for personalization by region and section."

msgid "project.exim.item.5"
msgstr "Seller and domain mapping with mirror IDs and partner activity status."

msgid "project.exim.item.6"
msgstr "Reusable MySQL gateway with connection pooling, retry logic, and explicit transaction control."

msgid "project.exim.tech"
msgstr "Python, Flask, MySQL, SQL, REST API, connection pooling"

msgid "project.admin.title"
msgstr "Legacy Bravo Compatibility & Migration"

msgid "project.admin.summary"
msgstr "Compatibility layer and migration flows between the new dispatch service and the legacy Bravo/global_bravo subscription ecosystem."

msgid "project.admin.item.1"
msgstr "Best-effort sync back to legacy Subscribe and SubscribeHistory tables."

msgid "project.admin.item.2"
msgstr "Preservation and generation of legacy SID identifiers for subscriber compatibility."

msgid "project.admin.item.3"
msgstr "Synchronization of cities and sections between new and old schemas."

msgid "project.admin.item.4"
msgstr "Background import of subscribers, filters, history, cities, and sections from legacy tickets tables."

msgid "project.admin.item.5"
msgstr "Support for legacy CRM flows and multilingual subscribe/unsubscribe templates in the Bravo ecosystem."

msgid "project.admin.item.6"
msgstr "Safe handling of null dates and schema differences between old and new databases."

msgid "project.admin.tech"
msgstr "Python, Flask, MySQL, SQL, data migration, legacy systems"

