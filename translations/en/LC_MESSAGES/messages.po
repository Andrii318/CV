msgstr "Admin Module for Smarticket / Bravo"

msgid "project.admin.summary"
msgstr "One of the first backend modules for an internal admin panel."

msgid "project.admin.item.1"
msgstr "Flask routes for managing relations between users, halls, and producers."

msgid "project.admin.item.2"
msgstr "Adding and deleting relations between a user and a hall."

msgid "project.admin.item.3"
msgstr "Adding and deleting relations between a user and a producer."

msgid "project.admin.item.4"
msgstr "Dependency checks before deletion to prevent removing entities connected with sessions."

msgid "project.admin.item.5"
msgstr "Rendering HTML templates with Jinja. JavaScript functions for AJAX requests and dynamic interface updates."

msgid "project.admin.item.6"
msgstr "Handling success and error responses on the frontend side."

