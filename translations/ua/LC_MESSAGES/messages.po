msgid "project.technologies"
msgstr "Технології:"

msgid "project.subscription.title"
msgstr "Email Subscription & Dispatch Module"

msgid "project.subscription.summary"
msgstr "Backend-модуль для керування email-підписками, підтвердженням підписки, логікою відписки та масовими email-кампаніями."

msgid "project.subscription.item.1"
msgstr "Підтвердження підписки через одноразовий код підтвердження."

msgid "project.subscription.item.2"
msgstr "Зберігання та валідація кодів підтвердження на базі Redis."

msgid "project.subscription.item.3"
msgstr "Активація підписок new_events і super_price."

msgid "project.subscription.item.4"
msgstr "Email-сповіщення про зміну статусу підписки."

msgid "project.subscription.item.5"
msgstr "Масова відправка листів підписникам."

msgid "project.subscription.item.6"
msgstr "Фільтрація контенту за мовою, містами, секціями та історією замовлень клієнта."

msgid "project.subscription.item.7"
msgstr "HTML email templates російською та івритом."

msgid "project.subscription.item.8"
msgstr "Логування відправки листів та обробка помилок."

msgid "project.subscription.tech"
msgstr "Python, Flask, MySQL, Redis, HTML Templates, Email, REST API, JavaScript"

msgid "project.mail_analyzer.title"
msgstr "Mail Analyzer / Bounce Email Processing"

msgid "project.mail_analyzer.summary"
msgstr "Модуль для аналізу bounce/DSN-повідомлень і виявлення email-адрес з проблемами доставки."

msgid "project.mail_analyzer.item.1"
msgstr "Інтеграція Gmail API через OAuth."

msgid "project.mail_analyzer.item.2"
msgstr "Обробка вхідних email-повідомлень."

msgid "project.mail_analyzer.item.3"
msgstr "Парсинг MIME/DSN-структур і заголовків X-Failed-Recipients."

msgid "project.mail_analyzer.item.4"
msgstr "Витягування проблемних email-адрес із заголовків і тіла листа."

msgid "project.mail_analyzer.item.5"
msgstr "Обробка кейсів user unknown, mailbox unavailable, address not found, quarantine/spam, inactive email та changed email address."

msgid "project.mail_analyzer.item.6"
msgstr "Аналіз тексту листів на основі регулярних виразів."

msgid "project.mail_analyzer.item.7"
msgstr "Формування JSON-звітів для кандидатів на відписку. Використання OpenAI API як fallback для складного аналізу тексту листів."

msgid "project.mail_analyzer.tech"
msgstr "Python, Gmail API, OAuth, Regex, MySQL, JSON, OpenAI API"

msgid "project.exim.title"
msgstr "Exim Mail Log Analyzer"

msgid "project.exim.summary"
msgstr "Невеликий внутрішній CLI-інструмент для аналізу логів поштового сервера Exim. Проєкт ще в процесі розробки."

msgid "project.exim.item.1"
msgstr "Аналіз файлів mainlog і архівних mainlog.*.gz за вибраний період часу."

msgid "project.exim.item.2"
msgstr "Пошук записів про failed і deferred доставку."

msgid "project.exim.item.3"
msgstr "Витягування email-адрес із логів Exim."

msgid "project.exim.item.4"
msgstr "Класифікація проблем: nonexistent user, unavailable mailbox, typo domain, temporary errors, блокування Spamhaus."

msgid "project.exim.item.5"
msgstr "Генерація звітів .txt, .csv і summary.txt."

msgid "project.exim.item.6"
msgstr "Генерація SQL import file для обробки відписки."

msgid "project.exim.tech"
msgstr "Python, Regex, CSV, Gzip, CLI, Exim logs, SQL"

msgid "project.admin.title"
msgstr "Admin Module for Smarticket / Bravo"

msgid "project.admin.summary"
msgstr "Один із перших backend-модулів для внутрішньої адміністративної панелі."

msgid "project.admin.item.1"
msgstr "Flask routes для керування зв'язками між користувачами, залами та продюсерами."

msgid "project.admin.item.2"
msgstr "Додавання та видалення зв'язків між користувачем і залом."

msgid "project.admin.item.3"
msgstr "Додавання та видалення зв'язків між користувачем і продюсером."

msgid "project.admin.item.4"
msgstr "Перевірки залежностей перед видаленням, щоб не видаляти сутності, пов'язані із сесіями."

msgid "project.admin.item.5"
msgstr "Рендеринг HTML templates з Jinja. JavaScript-функції для AJAX-запитів і динамічного оновлення інтерфейсу."

msgid "project.admin.item.6"
msgstr "Обробка успішних і помилкових відповідей на стороні frontend."

msgid "project.admin.tech"
msgstr "Python, Flask, MySQL, Jinja, JavaScript, HTML, Bootstrap"

